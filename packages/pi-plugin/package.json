    "directory": "packages/pi-plugin"
  },
  "keywords": [
    "pi",
    "pi-ai",
    "context-window",
    "context-compaction",
    "rolling-fold",
    "prompt-cache",
    "function-calling",
    "agents",
    "deterministic",
    "infinite-context"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
